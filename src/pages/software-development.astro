---
import Header from '../components/Header.astro';
import Project from "../components/Project.astro";
import Sidebar from "../components/Sidebar.astro";
import { getCollection } from 'astro:content';

const projects = await getCollection('projects', ({ data }) => data.category === 'software-development');
projects.sort((a, b) => a.data.order - b.data.order);
const projectPromises = projects.map(async (project) => {
    const { Content } = await project.render();
    return {
        ...project,
        Content,
    };
});
const renderedProjects = await Promise.all(projectPromises);
---

<!DOCTYPE html>
<html>
  <Header title="Software Development | Paul Abrams" />
  <body>
    <div class="content">
        <Sidebar selectedItem="software-development" />
      <nav class="main">
        <div class="container">
          <div class="back-nav-container">
            <a href="/" class="back-nav-button w-inline-block"
              ><img src="/assets/back.svg" loading="lazy" alt="" class="back-nav-img" />
              <div>Back</div></a
            >
          </div>
          <div class="content-container">
            <h1>Software Development</h1>
            <p class="lead">Professional experience building enterprise web applications, modernizing legacy systems, and delivering working software across the Government of Canada and private sector.</p>
            <section class="items-container">
                <div class="resouce-items">
                    {renderedProjects.map(({ data, Content }) => (
                      <Project
                        title={data.title}
                        desc={Content}
                        tech={data.tech}
                        image={data.image}
                        url={data.url}
                      />
                    ))}
                  </div>
            </section>
          </div>
        </div>
      </nav>
    </div>
  </body>
</html>
