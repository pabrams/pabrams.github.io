---
const { title, desc: Desc, tech, image, url } = Astro.props;
---

<div class="single-item">
  <h3>{url ? <a href={url} target="_blank" rel="noopener noreferrer" style="color: #fff; text-decoration: none; border-bottom: 1px solid #555;">{title}</a> : title}</h3>
  {image && (
    <a href={url || "#"} target="_blank" rel="noopener noreferrer">
      <img src={image} alt={title} class="project-image" loading="lazy" />
    </a>
  )}
  <div class="project-desc project-desc-list w-richtext">
    <Desc />
  </div>
  <div class="mini-label-white">Technologies &amp; tools</div>
  <div class="chips-container">
    {tech.map(techItem => <div class="single-chip">{techItem}</div>)}
  </div>
</div>
