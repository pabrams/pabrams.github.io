---
import Header from "../components/Header.astro";
import Sidebar from "../components/Sidebar.astro";
---


<!DOCTYPE html>
<html>
  <Header title="Paul Abrams" />
  <body>
    <div class="content">
      <Sidebar selectedItem="home" />
      <nav class="main">
        <div class="container">
          <main class="fold-content-container">
            <div class="fold-content">
              <h1>I'm Paul Abrams, I deliver Enterprise software solutions</h1>
            </div>
            <a href="mailto:j.paul.abrams@protonmail.com	" class="button w-button">Contact</a>
          </main>
          <div class="projects-section">
            <!-- Software Development -->
            <a href="/software-development" class="projects-container">
              <div class="single-projects-category">
                <div class="projects-category-image-container">
                  <img src="./assets/browser.svg" loading="lazy" alt="" class="projects-category-image" />
                </div>
              </div>
              <div class="single-projects-content">
                <h4>Software Development</h4>
                <div class="tech-tools-container">
                  <div class="mini-label-white gray-color">Technologies</div>
                  <div class="chips-container chips-container-small-width">
                    <div class="single-chip small-chip">React</div>
                    <div class="single-chip small-chip">Node.js</div>
                    <div class="single-chip small-chip">TypeScript</div>
                    <div class="single-chip small-chip">JavaScript</div>
                    <div class="single-chip small-chip">C#</div>
                    <div class="single-chip small-chip">.NET</div>
                    <div class="single-chip small-chip">SQL</div>
                    <div class="single-chip small-chip">ASP .NET</div>
                    <div class="single-chip small-chip">ADODB</div>
                    <div class="single-chip small-chip">Java</div>

                  </div>
                </div>
              </div>
            </a>
            <!-- DevOps & Cloud -->
            <a href="/devops" class="projects-container">
              <div class="single-projects-category">
                <div class="projects-category-image-container devops-img">
                  <img src="./assets/database.svg" loading="lazy" alt="" class="projects-category-image" />
                </div>
              </div>
              <div class="single-projects-content">
                <h4>DevOps &amp;&nbsp;Cloud</h4>
                <div class="tech-tools-container">
                  <div class="mini-label-white gray-color">Technologies &amp; tools</div>
                  <div class="chips-container chips-container-small-width">
                    <div class="single-chip small-chip">Azure DevOps Services (ADO)</div>
                    <div class="single-chip small-chip">ADO Pipelines (Build/Release)</div>
                    <div class="single-chip small-chip">CI/CD</div>
                    <div class="single-chip small-chip">PowerShell</div>
                    <div class="single-chip small-chip">Git</div>
                    <div class="single-chip small-chip">Terraform</div>
                    <div class="single-chip small-chip">Azure</div>
                    <div class="single-chip small-chip">AWS</div>
                    <div class="single-chip small-chip">Docker</div>
                    <div class="single-chip small-chip">Kubernetes</div>
                    <div class="single-chip small-chip">GitHub CI/CD</div>
                    <div class="single-chip small-chip">Linux</div>
                    <div class="single-chip small-chip">Bash</div>
                  </div>
                </div>
              </div>
            </a>
          </div>
        </div>
      </nav>
    </div>

    <!--[if lte IE 9]><script src="//cdnjs.cloudflare.com/ajax/libs/placeholders/3.0.2/placeholders.min.js"></script><![endif]-->
  </body>
</html>