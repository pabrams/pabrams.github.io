---
import Header from '../components/Header.astro';
import Project from "../components/Project.astro";
import Sidebar from "../components/Sidebar.astro";
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
const projectPromises = projects.map(async (project) => {
    const { Content } = await project.render();
    return {
        ...project,
        Content,
    };
});
const renderedProjects = await Promise.all(projectPromises);
---

<!DOCTYPE html>
<html
>
  <Header title="Personal Projects | Paul Abrams" />
  <body>
    <div class="content">
        <Sidebar selectedItem="personal-projects" />
      <nav class="main">
        <div class="container">
          <div class="back-nav-container">
            <a href="/" class="back-nav-button w-inline-block"
              ><img src="/assets/back.svg" loading="lazy" alt="" class="back-nav-img" />
              <div>Back</div></a
            >
          </div>
          <div class="content-container">
            <h1>Personal Projects</h1>
            <section class="items-container">
                <div class="resouce-items">
                    {renderedProjects.map(({ data, Content }) => (
                      <Project 
                        title={data.title} 
                        desc={Content}
                        tech={data.tech}
                      />
                    ))}
                  </div>
            </section>
          </div>
        </div>
      </nav>
    </div>

    <!--[if lte IE 9]><script src="//cdnjs.cloudflare.com/ajax/libs/placeholders/3.0.2/placeholders.min.js"></script><![endif]-->
  </body>
</html>
